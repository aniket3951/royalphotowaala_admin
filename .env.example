# Royal Photowaala - Environment Configuration

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# MongoDB (Recommended)
MONGODB_URI=mongodb://localhost:27017/royalphotowaala

# Security
JWT_SECRET=royalphotowaala-secret-key-2024-change-in-production
SESSION_SECRET=royalphotowaala-session-secret-2024

# File Upload Configuration
MAX_FILE_SIZE=104857600
UPLOAD_PATH=./uploads

# Cloudinary Configuration (OPTIONAL - Only if you want professional image hosting)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key  
# CLOUDINARY_API_SECRET=your-api-secret

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Production Settings (uncomment for production)
# NODE_ENV=production
# JWT_SECRET=your-super-secure-jwt-secret-for-production
# ALLOWED_ORIGINS=https://yourdomain.com
# LOG_LEVEL=error
