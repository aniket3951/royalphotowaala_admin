# Royal Photowaala - Environment Configuration

# Database Configuration (Prisma + PostgreSQL)
# For local development:
DATABASE_URL="postgresql://user:password@localhost:5432/royalphotowaala"

# For production (Render):
# DATABASE_URL="postgresql://user:password@host:port/database"

# Server Configuration
PORT=5000
NODE_ENV=development

# Security
JWT_SECRET=royalphotowaala-secret-key-2024-change-in-production

# File Upload Configuration
MAX_FILE_SIZE=20971520

# Cloudinary Configuration (OPTIONAL - For production image hosting)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key  
# CLOUDINARY_API_SECRET=your-api-secret

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000
